{
  "name": "vm-tippe",
  "version": "0.1.0",
  "private": true,
  "description": "MVP for VM-tipping med React, Express og PostgreSQL.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "start": "npm run start --workspace server",
    "build": "npm run build --workspace client",
    "build:pages": "npm run build && node scripts/prepare-gh-pages.mjs",
    "deploy": "npm run build:pages && gh-pages -d client/dist",
    "lint": "npm run lint --workspace client"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
